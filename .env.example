# Backend
APP_NAME=FixFlow
ENVIRONMENT=development
PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (Docker Compose sets these automatically via environment: block)
DATABASE_URL=postgresql://fixflow:fixflow_pass@db:5432/fixflow

# Postgres (used in docker-compose.prod.yml)
POSTGRES_DB=fixflow
POSTGRES_USER=fixflow
POSTGRES_PASSWORD=fixflow_pass

# CI/CD (set in GitHub Actions secrets)
REGISTRY=ghcr.io/nedavi
IMAGE_TAG=latest
